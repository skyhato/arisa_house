/* 页面容器：背景色、上下预留空间（和 contact-page 一样） */
.sponsor-page {
  min-height: 100vh;
  background: #dfc9f1;      /* 和消息通知那页一致的淡紫 */
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-top: 200rpx;       /* 顶部留给 .global-header */
  padding-bottom: 160rpx;    /* 底部留给返回按钮 */
  padding-left: 24rpx;
  padding-right: 24rpx;
}

/* 赞助卡片 */
.sponsor-card {
  background: #ffffff;
  border-radius: 30rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.08);
}

.sponsor-line {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.sponsor-time {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #777;
}

/* 无记录占位 */
.empty {
  margin-top: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

/* 底部返回按钮：沿用 contact 页样式 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: center;
  z-index: 99;
}

.back-btn {
  width: 320rpx;
  background: #aa66dd;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 50rpx;
  box-shadow: 0 6rpx 16rpx rgba(170,102,221,0.35);
}

.back-btn:active {
  background: #9b55cc;
}
