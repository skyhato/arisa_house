<navigation-bar
  title="照片详情"
  back="{{true}}"
  color="black"
  background="#FFF">
</navigation-bar>

<view class="page">

  <!-- ① 用户信息：头像 + 昵称 + 精选标记（保留活动封面背景，但去掉活动标签） -->
  <view class="user-row{{isFeatured ? ' featured' : ''}}">

    <!-- ✅ 活动封面背景（右侧保留） -->
    <image
      wx:if="{{isActivity && activityCoverUrl}}"
      class="user-bg"
      src="{{activityCoverUrl}}"
      mode="aspectFill"
    ></image>
    <view
      wx:if="{{isActivity && activityCoverUrl}}"
      class="user-bg-gradient"
    ></view>

    <image
      class="avatar"
      src="{{avatarUrl || '/assets/default-avatar.png'}}"
      mode="aspectFill"
      bindtap="onAvatarTap"
    ></image>

    <text class="nickname">{{nickname || '匿名用户'}}</text>

    <!-- ✅ 精选照片标签（原样保留）：紧跟昵称后 -->
    <view class="featured-badge" wx:if="{{isFeatured}}">
      <text class="featured-text">精选照片</text>
      <text class="featured-q" bindtap="onShowFeaturedIntro">?</text>
    </view>

  </view>

  <!-- ② 原图 -->
  <image
    class="photo"
    src="{{imageUrl}}"
    mode="widthFix"
    wx:if="{{imageUrl}}"
    bindtap="onPreviewPhoto"
    show-menu-by-longpress="true"
  ></image>

  <!-- ③ 地点信息 -->
  <view class="card">
    <view class="card-title">信息</view>

    <view class="row">
      <text class="label">位置：</text>
      <text class="val">{{locationName || '未填写'}}</text>
    </view>

    <!-- ✅ 新增：地点信息下的角色信息（tag，自动换行） -->
    <view class="row row-tags">
      <text class="label">角色：</text>
      <view class="val tags-wrap">
        <block wx:if="{{roleTags && roleTags.length}}">
          <block wx:for="{{roleTags}}" wx:key="*this">
            <text class="tag">{{item}}</text>
          </block>
        </block>
        <block wx:else>
          <text class="tag tag--empty">未选择</text>
        </block>
      </view>
    </view>

    <view class="row">
      <text class="label">经纬度：</text>
      <text class="val">{{latitude}}, {{longitude}}</text>
    </view>
  </view>

  <!-- ④ 用户留言 -->
  <view class="card" wx:if="{{commentEnabled}}">
    <view class="card-title">留言</view>
    <view class="msg">{{message || '（无）'}}</view>
  </view>

  <!-- ⑤ 评论区（受全局开关控制） -->
  <view class="card" wx:if="{{commentEnabled}}">
    <view class="card-title">评论</view>

    <!-- 评论列表 -->
    <block wx:if="{{comments && comments.length}}">
      <view class="comment-item" wx:for="{{comments}}" wx:key="_id" wx:for-item="item">
        <image
          class="comment-avatar"
          src="{{item.avatarUrl || '/assets/default-avatar.png'}}"
          mode="aspectFill"
        ></image>
        <view class="comment-main">
          <view class="comment-head">
            <text class="comment-name">{{item.nickname || '匿名用户'}}</text>
            <text class="comment-time">{{item.createdAtText}}</text>
          </view>
          <view class="comment-content">{{item.content}}</view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view
        class="load-more"
        wx:if="{{!commentsFinished}}"
        bindtap="onLoadMoreComments"
      >
        {{loadingComments ? '加载中…' : '加载更多'}}
      </view>
      <view class="load-done" wx:elif="{{commentsFinished}}">
        已显示全部
      </view>
    </block>

    <!-- 无评论 -->
    <view class="comment-empty" wx:else>
      期待您的评论！
    </view>

    <!-- 评论输入框 -->
    <view class="comment-input-row">
      <input
        class="comment-input"
        placeholder="输入框，友善发言"
        maxlength="300"
        value="{{commentInput}}"
        bindinput="onCommentInput"
      />
      <button
        class="comment-send"
        loading="{{sendingComment}}"
        bindtap="onSubmitComment"
      >
        发布
      </button>
    </view>
  </view>

  <!-- 管理操作卡片：编辑 + 删除（发布者/管理员可见） -->
  <view class="card delete-card" wx:if="{{canDelete || canEdit}}">
    <view class="card-title">管理操作</view>

    <!-- 顶部按钮区 -->
    <view class="op-btns">
      <button
        class="edit-btn"
        wx:if="{{canEdit && !editing}}"
        bindtap="onStartEdit"
      >编辑信息</button>

      <button
        class="delete-btn"
        bindtap="onDeletePhotoTap"
        loading="{{deletingPhoto}}"
      >删除这张照片</button>
    </view>

    <!-- 编辑面板 -->
    <view class="edit-panel" wx:if="{{editing}}">
      <!-- 位置：仅按钮选择，禁止手输 -->
      <view class="row" style="align-items:center;">
        <text class="label">位置：</text>
        <view class="val" style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
          {{editLocationName || '未选择'}}
        </view>
        <button class="pick-loc-btn" size="mini" bindtap="onChooseLocation">选择位置</button>
      </view>

      <!-- 留言 -->
      <view class="row" style="align-items:flex-start;">
        <text class="label">留言：</text>
        <textarea
          class="edit-textarea"
          placeholder="请输入留言（≤500字）"
          maxlength="500"
          auto-height
          value="{{editMessage}}"
          bindinput="onEditMessageInput"
        />
      </view>

      <!-- 角色（可滑动多选） -->
      <view class="row">
        <text class="label">角色：</text>
        <view class="val">（可多选）</view>
      </view>

      <!-- ✅ 改这里：用 _id 作为 data-id 与 checkbox 的 value -->
      <scroll-view scroll-y class="role-scroll" style="max-height:420rpx;padding:16rpx;border:1rpx solid #eef0f3;border-radius:20rpx;background:#f7f8fa;box-sizing:border-box;margin-top:8rpx;">
        <view class="role-list">
          <label
            class="role-item"
            wx:for="{{roleList}}"
            wx:for-item="item"
            wx:key="_id"
            data-id="{{item._id}}"
            bindtap="onToggleRole"
            style="display:flex;align-items:center;gap:12rpx;margin-bottom:16rpx;font-size:28rpx;color:#333;"
          >
            <checkbox value="{{item._id}}" checked="{{!!editSelectedRoleIds[item._id]}}"/>
            <text class="role-name">{{item.name}}</text>
          </label>
        </view>
      </scroll-view>

      <view class="edit-actions" style="display:flex;gap:20rpx;margin-top:20rpx;">
        <button class="save-btn" loading="{{savingEdit}}" bindtap="onSaveEdit">保存</button>
        <button class="cancel-btn" bindtap="onCancelEdit">取消</button>
      </view>
    </view>
  </view>

  <!-- ⑥ 底部操作条：点赞 + 返回 -->
  <view class="footer">
    <button
      class="btn-like {{hasLiked ? 'liked' : ''}}"
      bindtap="onLikeTap"
      loading="{{isLiking}}"
    >
      <text class="like-text">{{hasLiked ? '已赞' : '点赞'}}</text>
      <text class="like-count">{{likesCount}}</text>
    </button>
    <button class="btn-back" bindtap="goBack">返回</button>
  </view>

</view>
