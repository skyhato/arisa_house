/* pages/publish/publish.wxss */

/* 背景与安全底部 */
.page {
  min-height: 100vh;
  background: #DFC9F1;
  padding: 50rpx 24rpx 120rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 容器 */
.container {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  box-sizing: border-box;
}

/* 通用卡片（圆角 50） */
.card {
  width: 100%;
  background: #fff;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.06);
  padding: 22rpx 22rpx 26rpx;
  box-sizing: border-box;
}

/* 分区标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

/* ===== 上传框 ===== */
.upload-box {
  padding: 0;
  overflow: hidden;
  height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.upload-preview {
  width: 100%;
  height: 100%;
  display: block;
  background: #eee;
}

.upload-empty {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.upload-hint {
  font-size: 32rpx;
  font-weight: 700;
  color: #aa66dd;
}

.upload-sub {
  font-size: 24rpx;
  color: #999;
}

/* ===== 每日次数卡片 ===== */
.quota-card {
  background: rgba(255,255,255,0.96);
}

.quota-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #222;
  margin-bottom: 14rpx;
}

.quota-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}

.quota-row.sub {
  padding-top: 2rpx;
}

.quota-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 700;
}

.quota-value {
  font-size: 30rpx;
  font-weight: 900;
  color: #AA66DD;
}

.quota-sub {
  font-size: 24rpx;
  color: #777;
}

.quota-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

/* ===== 选择项（地点/角色/活动） ===== */
.kv {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.kv-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 700;
}

.kv-value {
  font-size: 28rpx;
  color: #222;
  line-height: 1.5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ✅ tag 展示 */
.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding-top: 4rpx;
}

.tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(170, 102, 221, 0.12);
  border: 2rpx solid rgba(170, 102, 221, 0.18);
  color: #7d3fc4;
  font-size: 24rpx;
  font-weight: 700;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 留言输入 ===== */
.message-input {
  width: 100%;
  min-height: 96rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #222;
  background: #f7f8fa;
  border: 2rpx solid #eef0f3;
  border-radius: 26rpx;
  box-sizing: border-box;
  line-height: 1.7;
}

/* ===== 用户信息 ===== */
.user {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #f2f2f2;
  overflow: hidden;
  flex: 0 0 auto;
}

.nickname {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 注意事项 ===== */
.notice-box {
  background: rgba(255,255,255,0.92);
}

.notice-item {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  padding: 10rpx 0;
}

/* ===== Button：统一修复圆角/颜色失效 ===== */
button::after { border: none !important; }

.btn {
  border-radius: 50rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 26rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
  box-sizing: border-box;
}

.btn-mini {
  height: 72rpx;
  min-width: 180rpx;
  font-size: 28rpx;
  padding: 0 22rpx;
  flex: 0 0 auto;
}

.btn-full {
  width: 100%;
  height: 90rpx;
}

.btn-primary {
  background-color: #AA66DD;
  color: #fff;
  box-shadow: 0 10rpx 24rpx rgba(170, 102, 221, 0.25);
}
.btn-primary:active { opacity: 0.92; }

.btn-ghost {
  background: #fff;
  color: #333;
  border: 2rpx solid #e9e9e9;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.06);
}
.btn-ghost:active { opacity: 0.92; }
.btn[disabled] { opacity: 0.55; }

/* ====== 底部弹层：遮罩 + 半屏 ====== */
.mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,0.42);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.sheet {
  width: 100%;
  background: #fff;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  box-shadow: 0 -12rpx 30rpx rgba(0,0,0,0.18);
  padding: 18rpx 22rpx 20rpx;
  box-sizing: border-box;
  max-height: 76vh;
  display: flex;
  flex-direction: column;
}

.sheet-header {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
  padding: 10rpx 6rpx 12rpx;
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}
.sheet-sub {
  font-size: 24rpx;
  color: #888;
  font-weight: 600;
}

/* ✅ 关键：scroll-view 必须有明确高度才能稳定滚动 */
.sheet-body {
  height: 52vh;
  padding: 6rpx 6rpx 12rpx;
  box-sizing: border-box;
}

/* 列表项 */
.pick-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 8rpx;
  border-bottom: 1rpx solid #f2f3f5;
}

.pick-name {
  font-size: 28rpx;
  color: #333;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部按钮区 */
.sheet-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 12rpx;
}
.sheet-actions .btn-mini {
  flex: 1;
  min-width: 0;
}

/* 审核关闭时显示 */
.closed-wrap {
  min-height: calc(100vh - 100rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.closed-text {
  font-size: 36rpx;
  color: #333;
  font-weight: 700;
  text-align: center;
}

/* 进出场动画 */
.mask-in { animation: maskIn .18s ease-out forwards; }
.mask-out { animation: maskOut .18s ease-in forwards; }

.sheet-in { animation: sheetIn .18s ease-out forwards; }
.sheet-out { animation: sheetOut .18s ease-in forwards; }

@keyframes maskIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes maskOut { from { opacity: 1; } to { opacity: 0; } }

@keyframes sheetIn { from { transform: translateY(30rpx); opacity: 0.9; } to { transform: translateY(0); opacity: 1; } }
@keyframes sheetOut { from { transform: translateY(0); opacity: 1; } to { transform: translateY(30rpx); opacity: 0.9; } }
