/* pages/index/index.wxss */
page, .page {
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
  background: #f7f8fa;
  overflow-x: hidden;
  overflow-y: auto;
}

/* ===== 悬浮按钮 ===== */
.fab {
  position: fixed;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.18);
  z-index: 100; /* 始终在最上层，防止被遮罩挡住 */
}

.fab-publish {
  bottom: 40rpx;
  background-color: #1aad19;
}

.fab-filter {
  bottom: 160rpx;
  background-color: #aa66dd;
}

.plus {
  font-size: 60rpx;
  line-height: 100rpx;
  color: #fff;
}

/* ===== 筛选面板与遮罩 ===== */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 90; /* 在 fab 下方，在面板上方 */
}

/* ☆☆☆ 改动：半屏 + 内部滚动（仅新增/覆盖以下几行） */
.filter-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  padding: 32rpx 28rpx 48rpx;
  box-shadow: 0 -10rpx 30rpx rgba(0,0,0,0.1);
  z-index: 95; /* 在遮罩上方 */
  animation: slideUp 0.25s ease-out;

  /* ↓ 新增：半屏容器 + 垂直布局，让中间区域可滚动 */
  height: 50vh;
  display: flex;
  flex-direction: column;
}

/* 面板动画 */
@keyframes slideUp {
  from { transform: translateY(100%); opacity: 0; }
  to   { transform: translateY(0); opacity: 1; }
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  text-align: left;
  color: #333;
}

.role-item {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 20rpx 8rpx;
  border-bottom: 1rpx solid #f2f3f5;
}

.role-name {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #333;
}

/* ☆☆☆ 新增：筛选列表滚动区域（与 wxml 的 .panel-body 对应） */
.panel-body {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  max-height: calc(50vh - 160rpx); /* 保护性上限，避免极端机型溢出 */
}

/* ===== 面板按钮样式 ===== */
.panel-actions {
  display: flex;
  justify-content: flex-end;
  gap: 28rpx;
  margin-top: 36rpx;
}

.btn {
  min-width: 200rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  line-height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.2s ease;
}

.btn.primary {
  background-color: #AA66DD;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(170,102,221,0.3);
}

.btn.ghost {
  background-color: #fff;
  color: #333;
  border: 2rpx solid #e0e0e0;
}

.btn.primary:active { background-color: #994ECF; }
.btn.ghost:active   { background-color: #f5f5f5; }

/* 覆盖全屏遮罩：点击空白可关闭 */
.ad-mask {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.55);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 中央卡片容器（不裁剪，避免按钮被“吃掉”） */
.ad-card {
  position: relative;
  width: 84%;
  max-width: 680rpx;
  overflow: visible;
}

/* 图片：不需要圆角 */
.ad-img {
  width: 100%;
  display: block;
  position: relative;
  z-index: 0;
}

/* 关闭按钮：在图片之上 */
.ad-close {
  position: absolute;
  right: 0rpx;
  top: -50rpx;
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.65);
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  z-index: 2;
  touch-action: manipulation;
  -webkit-tap-highlight-color: transparent;
}

/* 顶部统计文字 */
.photo-count {
  position: fixed;
  top: 190rpx;
  width: 100%;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #aa66dd;
  z-index: 200;
  pointer-events: none;
}

/* 统计文字下的按钮容器 */
.photo-tools{
  position: fixed;
  top: 110rpx;
  width: 100%;
  display: flex;
  justify-content: center;
  z-index: 200;
}

.btn.region-btn{
  min-width: 360rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 30rpx;
  color: #fff;
  background: #aa66dd;
  box-shadow: 0 8rpx 20rpx rgba(108,92,231,0.25);
}

/* 半屏弹层：当前区域图片 */
.region-panel{
  position: fixed;
  left: 0; right: 0; bottom: 0;
  height: 50vh;
  background: #fff;
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  z-index: 120;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -10rpx 30rpx rgba(0,0,0,0.12);
  animation: slideUp 0.22s ease-out;
}
.region-header{
  padding: 20rpx 28rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}
.region-body{
  max-width: 100%;
  height: calc(50vh - 100rpx - 120rpx);
  padding: 20rpx 20rpx 8rpx;
}
.region-footer{
  padding: 16rpx 20rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: center;
}
.btn.back-btn{
  min-width: 300rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #333;
  background: #f5f5f5;
}

/* 两列网格 */
.grid{
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.grid-item{
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.06);
}
.grid-thumb{
  width: 100%;
  max-width: 100%;
  height: 260rpx;
  display: block;
}
.grid-caption{
  padding: 8rpx 12rpx 14rpx;
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.fab-refresh {
  bottom: 280rpx;
  background-color: #1E90FF;
}
/* 活动按钮（在刷新按钮上方） */
.fab-activity {
  bottom: 400rpx;            /* 比刷新(280rpx)更高一档 */
  background-color: #FF8C00; /* 橙色，和刷新蓝/随机紫区分 */
}

/* 左下角“猜猜宝”按钮 */
.fab-guess {
  position: fixed;
  left: 0rpx;                                /* 靠左 */
  bottom: calc(-0rpx + env(safe-area-inset-bottom));
  width: 150rpx;
  height: 150rpx;
  border-radius: 0;
  background: transparent;                    /* 让 PNG 自己控制样式 */
  padding: 0;
  box-shadow: none;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 99;
}

/* PNG 图标本体 */
.fab-guess-icon {
  width: 100%;
  height: 100%;
  border-radius: 0rpx;
  /* 你后面可以给 PNG 自带阴影/圆角，这里先简单一点 */
}
