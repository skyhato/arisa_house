/* pages/activity_detail/activity_detail.wxss */

/* 页面容器（留出 global-header 的空间） */
.activity-detail-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 100rpx 24rpx 24rpx;
  box-sizing: border-box;
}

/* 卡片（同列表页） */
.card {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  width: 96%;
  height: 500rpx;
  background: #fff;
  border-radius: 50rpx;
  margin-top: 100rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 40rpx;
  overflow: hidden;
}

.corner-star {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 70rpx;
  height: 70rpx;
  z-index: 3;
  pointer-events: none;
  filter: drop-shadow(0 6rpx 14rpx rgba(0,0,0,0.18));
}

/* 左侧缩略图 + 渐变 */
.thumb-wrap {
  width: 50%;
  height: 100%;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  border-top-left-radius: 50rpx;
  border-bottom-left-radius: 50rpx;
}
.thumb {
  width: 100%;
  height: 100%;
}
.thumb-wrap::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 90rpx;
  height: 100%;
  background: linear-gradient(to right, rgba(255,255,255,0), #ffffff);
  pointer-events: none;
  z-index: 2;
}

/* 右侧信息 */
.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.user {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #eee;
}
.nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.location,
.message {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: normal;
  min-height: 72rpx;
}

/* 点赞与时间 */
.meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}
.like-text {
  font-size: 34rpx;
  color: #FF4D4F;
  font-weight: 700;
}
.time {
  font-size: 24rpx;
  color: #999;
}

/* 按钮行 */
.btn-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  gap: 20rpx;
}

.btn {
  font-size: 26rpx;
  padding: 10rpx 28rpx;
  border-radius: 40rpx;
  font-weight: 500;
  color: #fff;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}
.btn.view { background: #AA66DD; }
.btn.like { background: #FF4D4F; }

/* 空态 */
.empty {
  margin-top: 120rpx;
  font-size: 28rpx;
  color: #888;
}

/* ✅ 右下角三个悬浮按钮（严格同列表页） */
.fab {
  position: fixed;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.18);
  z-index: 100;
}

.fab-publish {
  bottom: 40rpx;
  background-color: #1aad19;
}

.fab-filter {
  bottom: 160rpx;
  background-color: #AA66DD;
}

.fab-sort {
  bottom: 280rpx;
  background-color: #1E90FF;
}

.plus {
  font-size: 60rpx;
  color: #fff;
  line-height: 100rpx;
}

.fab-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1;
  text-align: center;
}

/* ✅ 通用遮罩（同列表页） */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 90;
}

/* ✅ 底部面板（筛选/排序共用，同列表页） */
.filter-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  padding: 32rpx 28rpx 48rpx;
  box-shadow: 0 -10rpx 30rpx rgba(0,0,0,0.1);
  z-index: 95;
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); opacity: 0; }
  to   { transform: translateY(0); opacity: 1; }
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: #333;
}

.role-item {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 20rpx 8rpx;
  border-bottom: 1rpx solid #f2f3f5;
}

.role-name {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.panel-body {
  max-height: 600rpx;
}

.panel-actions {
  display: flex;
  justify-content: flex-end;
  gap: 28rpx;
  margin-top: 36rpx;
}

.btn.primary {
  background-color: #AA66DD;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(170, 102, 221, 0.3);
}

.btn.ghost {
  background-color: #fff;
  color: #333;
  border: 2rpx solid #e0e0e0;
}

.btn.primary:active { background-color: #994ECF; }
.btn.ghost:active { background-color: #f5f5f5; }

/* 排序面板专用（同列表页） */
.sort-title { color: #1E90FF; }
.sort-list { margin-top: 8rpx; }

.sort-item {
  padding: 24rpx 8rpx;
  font-size: 30rpx;
  color: #333;
  border-bottom: 1rpx solid #f2f3f5;
}

.sort-item.active {
  color: #1E90FF;
  font-weight: 700;
}

.btn.sort-primary {
  background-color: #1E90FF;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(30,144,255,0.3);
}

/* 加载更多 */
.load-more-wrapper {
  margin: 20rpx 0 40rpx;
  display: flex;
  justify-content: center;
}

.load-more-btn {
  padding: 16rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background-color: #AA66DD;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(170, 102, 221, 0.3);
}

.load-more-end {
  margin: 20rpx 0 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

/* ✅ 说明图弹窗（右上角关闭） */
.guide-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.55);
  z-index: 200;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.guide-panel {
  position: relative;
  width: 100%;
  max-width: 650rpx;
  background: #fff;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.25);
}

.guide-img {
  width: 100%;
  display: block;
}

.guide-close {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.55);
  color: #fff;
  font-size: 40rpx;
  line-height: 56rpx;
  text-align: center;
}
