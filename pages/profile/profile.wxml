<!-- pages/profile/profile.wxml -->
<view class="global-header">个人信息</view>

<view class="page">
  <view class="container">

    <!-- 基础信息 -->
    <view class="card">
      <view class="section-title">基础信息</view>

      <!-- 头像行：左 50% 头像 / 右 50% 按钮（右对齐） -->
      <view class="field">
        <view class="field-label">头像</view>
        <view class="field-row">
          <view class="field-left">
            <image class="avatar" src="{{avatarPreview || '/assets/default-avatar.png'}}" mode="aspectFill" />
          </view>
          <view class="field-right">
            <button class="btn btn-primary" bindtap="onChangeAvatar" loading="{{uploadingAvatar}}">
              更改
            </button>
          </view>
        </view>
      </view>

      <!-- 昵称行：左 50% 输入框 / 右 50% 按钮（右对齐） -->
      <view class="field">
        <view class="field-label">昵称</view>
        <view class="field-row">
          <view class="field-left">
            <input
              class="input"
              placeholder="输入你的昵称"
              value="{{nickname}}"
              maxlength="20"
              bindinput="onNicknameInput"
            />
          </view>
          <view class="field-right">
            <button class="btn btn-primary" bindtap="onSaveNickname" loading="{{savingNickname}}">
              保存
            </button>
          </view>
        </view>
      </view>
    </view>

    <!-- 管理员入口 -->
    <view class="card" wx:if="{{isAdmin}}">
      <view class="section-title">管理入口</view>
      <view class="btn-stack">
        <button class="btn btn-primary btn-full" bindtap="goToAudit">审核管理</button>
        <button class="btn btn-primary btn-full" bindtap="goToUserAdmin">用户管理</button>
      </view>
    </view>

    <!-- 账户操作 -->
    <view class="card">
      <view class="section-title">账户操作</view>
      <view class="btn-stack">
        <button class="btn btn-danger btn-full" bindtap="onLogout">退出登录</button>
        <button class="btn btn-ghost btn-full" bindtap="goBack">返回</button>
      </view>
    </view>

  </view>
</view>
