/* ================= 页面容器 ================= */
.container.works-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 200rpx 24rpx 160rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ================= 卡片 ================= */
.card {
  display: flex;
  flex-direction: column;
  width: 96%;
  background: #fff;
  border-radius: 50rpx;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.08);
  margin-bottom: 32rpx;
  overflow: hidden;
  transition: transform 0.12s ease-out;
}
.card:active { transform: translateY(-2rpx) scale(0.995); }

/* ================= 图片：占卡片2/3（用固定高度更稳） ================= */
.thumb-wrap {
  position: relative;
  width: 100%;
  height: 520rpx;                 /* ✅ 约占整卡片的2/3（下面文字+按钮撑开总高） */
  background: #eee;
}
.thumb-img {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 0 !important;
  transform: translateZ(0);
  backface-visibility: hidden;
}

/* ✅ 图片与文字交界渐变（从透明到白色） */
.thumb-fade {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 80rpx;
  background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,1));
  pointer-events: none;
}

/* ================= 信息区 ================= */
.info {
  width: 100%;
  display: flex;
  flex-direction: column;
  padding: 18rpx 22rpx 20rpx;
  box-sizing: border-box;
  overflow: hidden;
}

/* ================= 文本：小字号 + 稳定行高 ================= */
.row {
  font-size: 26rpx;
  color: #555;
  line-height: 34rpx;
  margin-top: 6rpx;
  overflow: hidden;
}
.label {
  font-size: 22rpx;
  color: #888;
  margin-top: 10rpx;
}

/* ✅ 地点/留言：只保留一行，超出省略号 */
.one-line {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ================= 角色标签（两行限制） ================= */
.role-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 10rpx;
  margin-top: 6rpx;
  max-height: 92rpx;
  overflow: hidden;
  align-content: flex-start;
}
.tag {
  padding: 4rpx 14rpx;
  font-size: 22rpx;
  line-height: 28rpx;
  border-radius: 999rpx;
  background: #f5f5f5;
  color: #555;
  border: 1rpx solid #e6e6e6;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.tag--empty {
  color: #999;
  background: #fafafa;
  border-style: dashed;
}
.tag--more{
  background: #eee;
  color: #666;
  border-style: solid;
}

/* ================= 状态三色 ================= */
.status { font-weight: 600; }
.status--approved { color: #16a34a; }
.status--pending  { color: #f59e0b; }
.status--rejected { color: #ef4444; }

/* 时间：单独一行 */
.status-row { margin-top: 10rpx; }
.time-text {
  display: block;
  margin-left: 0;
  margin-top: 4rpx;
  color: #999;
  font-size: 22rpx;
  line-height: 30rpx;
}

/* ================= 按钮：稍微大一点 ================= */
.btn-row {
  display: flex;
  flex-wrap: nowrap;
  justify-content: flex-end;
  align-items: center;
  margin-top: 14rpx;
  gap: 14rpx;
}
.btn {
  font-size: 26rpx;              /* ✅ 更大 */
  padding: 12rpx 26rpx;          /* ✅ 更大 */
  border-radius: 44rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
  max-width: 46%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.btn:active { opacity: 0.92; }
.btn-view   { background: #aa66dd; }
.btn-delete { background: #ff4d4f; }

/* ================= 空态 ================= */
.empty {
  margin-top: 120rpx;
  font-size: 28rpx;
  color: #888;
  text-align: center;
}

/* ================= 返回键样式（如果你已有全局样式，可删） ================= */
.footer {
  position: fixed;
  left: 0; right: 0;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: center;
}
.back-btn {
  width: 320rpx;
  background: #aa66dd;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 50rpx;
  box-shadow: 0 6rpx 16rpx rgba(139,92,246,0.35);
}
