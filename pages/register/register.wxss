.register-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 120rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 600;
  margin-bottom: 60rpx;
}

.avatar-btn {
  background: transparent;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  background: #f5f5f5;
}

.avatar-tip {
  margin-top: 12rpx;
  color: #666;
  font-size: 26rpx;
}

.nick-input {
  width: 72%;
  height: 88rpx;
  line-height: 88rpx;
  margin: 50rpx 0 30rpx;
  border: 1rpx solid #ddd;
  border-radius: 24rpx;
  text-align: center;
  font-size: 30rpx;
}

/* ✅ 修改部分：让按钮内的文字始终上下居中 */
.btn-submit,
.btn-back {
  display: flex;
  justify-content: center;
  align-items: center;  /* 垂直居中 */
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  box-sizing: border-box;
}

/* 保留原配色与尺寸 */
.btn-submit {
  width: 72%;
  height: 88rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 44rpx;
}

.btn-back {
  margin-top: 24rpx;
  width: 60%;
  height: 88rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 36rpx;
}
