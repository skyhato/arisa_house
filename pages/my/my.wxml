<!--
  页面：my
  作用：
  1. 展示当前登录用户信息
  2. 展示 UID、昵称、头像
  3. 提供个人信息、我的作品、消息通知、精选照片等入口
  4. 支持“支持我们”暂时关闭态
-->

<view class="my-page">
  <!-- 顶部用户卡片 -->
  <view class="card user-card">
    <!-- 已登录状态 -->
    <block wx:if="{{user && user.openid}}">
      <image
        class="avatar"
        src="{{user.avatarUrlResolved || defaultAvatar}}"
        mode="aspectFill"
        binderror="onAvatarError"
      />
      <view class="info">
        <view class="name">{{ user.nickname || '微信用户' }}</view>
        <view class="sub">UID：{{ user.uid || '未生成' }}</view>
      </view>
    </block>

    <!-- 未登录状态 -->
    <block wx:else>
      <view class="login-wrapper">
        <button class="login-btn" bindtap="goLogin">登录 / 注册</button>
      </view>
    </block>
  </view>

  <!-- 功能区 -->
  <view class="card menu">
    <view class="menu-item" bindtap="goProfile">个人信息</view>
    <view class="menu-item" bindtap="goWorks">我的作品</view>

    <view class="menu-item notice-item" bindtap="goNotice">
      <text>消息通知</text>
      <view wx:if="{{hasNewNotice}}" class="red-dot"></view>
    </view>

    <view class="menu-item" bindtap="goFeatured">精选照片</view>

    <!-- 支持我们暂时关闭 -->
    <view wx:if="{{supportEnabled}}" class="menu-item" bindtap="goSupport">
      支持我们
    </view>
    <!-- <view wx:else class="menu-item disabled-item">
      <text>支持我们</text>
      <text class="disabled-tag">暂未开放</text>
    </view> -->
  </view>
</view>

<!-- 仅登录后显示退出按钮 -->
<button wx:if="{{user && user.openid}}" class="logout-btn" bindtap="onLogout">
  退出登录
</button>