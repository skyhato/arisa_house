/* pages/my/my.wxss */
.my-page {
  padding: 24rpx;
  box-sizing: border-box;
  margin-top: 160rpx;
  padding-bottom: 160rpx; /* 给底部固定按钮留空间 */
}

.card {
  background: #ffffff;
  /* border-radius: 20rpx; */
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.05);
  margin-bottom: 24rpx;
  overflow: hidden;
}

.user-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #f2f3f5;
  flex: 0 0 140rpx;
}

.info {
  margin-left: 24rpx;
  min-width: 0;
}

.name {
  font-size: 34rpx;
  font-weight: 600;
  color: #111;
}

.sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}

.menu {
  padding: 12rpx 0;
}

.menu-item {
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  border-top: 1rpx solid #f0f0f0;
}
.menu-item:first-child {
  border-top: none;
}

/* 未登录时的登录 / 注册按钮区域 */
.login-wrapper {
  width: 100%;
}

.login-btn {
  width: 100%;
  height: 120rpx;
  line-height: 100rpx;   /* 保证文字垂直居中 */
  text-align: center;
  border-radius: 999rpx;
  background: transparent;  /* 去掉颜色 */
  color: #000000;           /* 黑色字体 */
  font-size: 32rpx;
  font-weight: 600;
  border: none; 
  margin: 0;
}
.login-btn::after {
  border: none;
}

/* 底部固定 退出登录 按钮 */
.logout-btn {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: 40rpx;         /* ↑ 离底40rpx */
  border-radius: 50rpx;  /* ← 加圆角50rpx */
  background: #ff4d4f;
  color: #ffffff;
  font-size: 32rpx;
  padding: 24rpx 0;
  border: none;
  margin: 0;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15); /* 可选：让按钮更立体 */
}
.logout-btn::after {
  border: none;
}
/* 消息通知菜单项，用来放小红点 */
.notice-item {
  position: relative;
}

/* 小红点 */
.red-dot {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ff4d4f;
}
