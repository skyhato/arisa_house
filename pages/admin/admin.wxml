<!-- pages/admin/admin.wxml -->
<view class="works-page">
  <view class="header">审核管理</view>

  <!-- 搜索区 -->
  <view class="search-bar">
    <input
      class="search-input"
      type="number"
      placeholder="输入照片ID搜索"
      value="{{searchKey}}"
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearchConfirm"
    />
    <button class="search-btn" bindtap="onSearchConfirm">搜索</button>
    <button
      wx:if="{{searchKey || searchPhotoId}}"
      class="clear-btn"
      bindtap="onClearSearch"
    >
      清空
    </button>
  </view>

  <!-- 顶部工具栏 -->
  <view class="toolbar">
    <button
      class="batch-btn"
      bindtap="approveAllPending"
      loading="{{batchLoading}}"
      disabled="{{batchLoading || !hasPending || fixIdLoading}}"
    >
      {{ batchLoading ? '批量审核中...' : (hasPending ? '一键通过全部未审核' : '暂无待审核') }}
    </button>

    <button
      class="fixid-btn"
      bindtap="runFixPublishPhotoId"
      loading="{{fixIdLoading}}"
      disabled="{{fixIdLoading || batchLoading || loading}}"
    >
      {{ fixIdLoading ? '执行中...' : '补图片ID' }}
    </button>
  </view>

  <block wx:if="{{works.length > 0}}">
    <block wx:for="{{works}}" wx:for-item="item" wx:key="_id">
      <view class="card">
        <!-- 左图（点图预览原图） -->
        <image
          class="thumb"
          src="{{item.thumbUrl || defaultThumb}}"
          mode="aspectFill"
          data-id="{{item._id}}"
          bindtap="previewImage"
        />

        <!-- 右侧信息 -->
        <view class="info">
          <view class="meta">
            <view class="row">照片ID：{{item.photoId || '未分配'}}</view>
            <view class="row">上传者：{{item.nickname || '匿名用户'}}</view>
            <view class="row">地点：{{item.locationName || '未知'}}</view>
            <view class="row">活动：{{item.activityName || '（无）'}}</view>
            <view class="row">角色：{{item.roleNamesText || '（无）'}}</view>
            <view class="row">上传时间：{{item.createdAtText || '（无）'}}</view>
          </view>
        </view>

        <!-- 固定底部按钮栏 -->
        <view class="btn-bar">
          <button
            wx:if="{{item.status === 'PENDING'}}"
            class="btn approve"
            data-id="{{item._id}}"
            bindtap="approveWork"
          >通过</button>

          <button
            wx:elif="{{item.status === 'APPROVED'}}"
            class="btn return"
            data-id="{{item._id}}"
            bindtap="returnWork"
          >退回</button>

          <button
            class="btn delete"
            data-id="{{item._id}}"
            bindtap="deleteWork"
          >删除</button>
        </view>
      </view>
    </block>
  </block>

  <view wx:if="{{works.length > 0 && !searchPhotoId}}">
    <view wx:if="{{hasMore}}" class="load-more-wrapper">
      <button
        class="load-more-btn"
        bindtap="onLoadMore"
        loading="{{loading}}"
        disabled="{{loading}}"
      >
        {{loading ? '加载中...' : '加载更多'}}
      </button>
    </view>
    <view wx:else class="load-more-end">
      <text>已经到底啦</text>
    </view>
  </view>

  <block wx:if="{{works.length === 0}}">
    <view class="empty">
      {{ searchPhotoId ? '未找到该照片ID对应的作品' : '暂无作品' }}
    </view>
  </block>

  <view class="footer">
    <button class="back-btn" bindtap="goBack">返回</button>
  </view>
</view>