/* pages/featured/featured.wxss */

/* 页面整体 */
.rank-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 100rpx 24rpx 24rpx;
  box-sizing: border-box;
}

/* 顶部标题 */
.header {
  width: 100%;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 卡片容器 */
.card {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  width: 96%;
  height: 500rpx;
  background: #fff;
  border-radius: 50rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 40rpx;
  overflow: hidden;
  transition: transform 0.2s;
}

.card:hover {
  transform: translateY(-4rpx);
}

/* 左边缩略图 */
.thumb {
  width: 50%;
  height: 100%;
  object-fit: cover;
  border-top-left-radius: 50rpx;
  border-bottom-left-radius: 50rpx;
}

/* 右侧信息 */
.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
  overflow: hidden;
}

/* 用户信息 */
.user {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #eee;
}
.nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

/* 地点与留言 */
.location,
.message {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: normal;
  min-height: 72rpx;
}

/* 点赞与时间 */
.meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}
.like-text {
  font-size: 34rpx;
  color: #FF4D4F;
  font-weight: 700;
}
.time {
  font-size: 24rpx;
  color: #999;
}

/* 按钮行 */
.btn-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  gap: 20rpx;
}

/* 按钮样式 */
.btn {
  font-size: 26rpx;
  padding: 10rpx 28rpx;
  border-radius: 40rpx;
  font-weight: 500;
  color: #fff;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}
.btn.view { background: #AA66DD; }
.btn.like { background: #FF4D4F; }

/* 空态提示 */
.empty {
  margin-top: 120rpx;
  font-size: 28rpx;
  color: #888;
}

/* 加载更多按钮区域 */
.load-more-wrapper {
  margin: 20rpx 0 40rpx;
  display: flex;
  justify-content: center;
}

.load-more-btn {
  padding: 16rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background-color: #AA66DD;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(170, 102, 221, 0.3);
}

.load-more-end {
  margin: 20rpx 0 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

/* 兜底，避免影响下拉手势 */
:where(.rank-page) {
  min-height: 100vh;
  box-sizing: border-box;
}
