/* pages/userAdmin/userAdmin.wxss */

/* 页面整体 */
.user-admin-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  padding-top: 200rpx;      /* 顶部空出 header */
  padding-bottom: 180rpx;   /* 给底部按钮栏留空间 */
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  padding: 0 24rpx;
  background: #f5f5f7;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 通用按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
  font-size: 26rpx;
}

.search-btn {
  background: #aa66dd;
  color: #fff;
}

/* 排行切换 */
.sort-tabs {
  display: flex;
  margin-bottom: 24rpx;
  border-radius: 999rpx;
  background: #f5f5f7;
  padding: 6rpx;
}

.tab {
  flex: 1;
  text-align: center;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  border-radius: 999rpx;
  color: #666;
}

.tab.active {
  background: #aa66dd;
  color: #fff;
}

/* 用户列表区域：减去底部 bar 高度 */
.user-list {
  max-height: calc(100vh - 380rpx);
}

.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 用户卡片 */
.user-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 20rpx;
}

.user-main {
  display: flex;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #eee;
  margin-right: 20rpx;
}

.info {
  flex: 1;
}

.nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.meta {
  font-size: 24rpx;
  color: #888;
  line-height: 32rpx;
}

/* 操作区 */
.user-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.btn.danger {
  background: #ff4d4f;
  color: #fff;
}

/* 加载更多 */
.load-more-area {
  margin-top: 16rpx;
  padding-bottom: 20rpx;
  display: flex;
  justify-content: center;
}

.load-more-btn {
  background: #f0f0f0;
  color: #333;
  min-width: 260rpx;
}

.no-more {
  color: #999;
  font-size: 24rpx;
  padding: 20rpx 0;
}

/* ✅ 底部栏（返回按钮 + 用户统计） */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.back-btn {
  background: #aa66dd;
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 0 60rpx;
  height: 72rpx;
  font-size: 30rpx;
}

.user-count {
  font-size: 28rpx;
  color: #555;
}
