<view class="global-header">用户管理</view>

<view class="user-admin-page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="按昵称 / openid 搜索用户"
      value="{{searchKey}}"
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearchConfirm"
    />
    <button class="btn search-btn" size="mini" bindtap="onSearchConfirm">搜索</button>
  </view>

  <!-- 排行方式切换 -->
  <view class="sort-tabs">
    <view
      class="tab {{sortMode === 'time' ? 'active' : ''}}"
      data-mode="time"
      bindtap="onChangeSort"
    >
      按注册时间
    </view>
    <view
      class="tab {{sortMode === 'works' ? 'active' : ''}}"
      data-mode="works"
      bindtap="onChangeSort"
    >
      按作品数
    </view>
  </view>

  <!-- 工具按钮 -->
  <view class="tool-bar">
    <button
      class="btn tool-btn"
      bindtap="onRunFixUsersUid"
      loading="{{runningFix}}"
      disabled="{{runningFix || loading || loadingMore}}"
    >
      运行去重补 UID
    </button>
  </view>

  <!-- 用户列表 -->
  <scroll-view scroll-y class="user-list">
    <block wx:if="{{loading && items.length === 0}}">
      <view class="empty">加载中…</view>
    </block>

    <block wx:elif="{{!loading && items.length === 0}}">
      <view class="empty">暂无用户</view>
    </block>

    <block wx:else>
      <block wx:for="{{items}}" wx:key="_id" wx:for-item="item">
        <view class="user-card">
          <view class="user-main">
            <image
              class="avatar"
              src="{{item.avatarResolved || item.avatar || '/assets/default-avatar.png'}}"
              mode="aspectFill"
            />
            <view class="info">
              <view class="nickname">
                {{item.nickname || '未设置昵称'}}
              </view>

              <view class="meta">
                <text selectable="true">UID：{{item.uid || '未生成'}}</text>
              </view>

              <view class="meta">
                <text selectable="true">openid：{{item.openid}}</text>
              </view>

              <view class="meta">作品数：{{item.worksCount || 0}}</view>
              <view class="meta">注册时间：{{item.createTimeStr || '未知'}}</view>
            </view>
          </view>

          <view class="user-actions">
            <button
              class="btn danger"
              size="mini"
              data-openid="{{item.openid}}"
              bindtap="onDeleteUser"
            >
              删除用户及作品
            </button>
          </view>
        </view>
      </block>

      <!-- 加载更多 -->
      <view class="load-more-area">
        <button
          wx:if="{{hasMore}}"
          class="btn load-more-btn"
          bindtap="onLoadMore"
        >
          加载更多
        </button>
        <view wx:elif="{{!hasMore}}" class="no-more">
          已显示全部用户
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- 底部返回栏 + 总数 -->
  <view class="bottom-bar">
    <button class="btn back-btn" bindtap="onBack">返回</button>
    <text class="user-count">当前共有 {{total}} 位用户</text>
  </view>
</view>