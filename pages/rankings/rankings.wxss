/* 页面整体 */
.rank-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  /* background: #f5f6f8; */
  min-height: 100vh;
  padding: 100rpx 24rpx 24rpx;
  box-sizing: border-box;
}

/* 顶部标题 */
.header {
  width: 100%;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 卡片容器 */
.card {
  position: relative; /* 让 corner-star 绝对定位在卡片内 */
  display: flex;
  flex-direction: row;
  align-items: stretch;
  width: 96%;
  height: 500rpx;
  background: #fff;
  border-radius: 50rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 40rpx;
  overflow: hidden;
  transition: transform 0.2s;
}

.card:hover {
  transform: translateY(-4rpx);
}

/* 左上角星星（WXML 的 image 叠层；不旋转、不圆角） */
.corner-star {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 70rpx;
  height: 70rpx;
  z-index: 3;
  pointer-events: none;
  filter: drop-shadow(0 6rpx 14rpx rgba(0,0,0,0.18));
}

/* ===== 左侧缩略图：包一层用于渐变 ===== */
.thumb-wrap {
  width: 50%;
  height: 100%;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  border-top-left-radius: 50rpx;
  border-bottom-left-radius: 50rpx;
}

/* 图片本体 */
.thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 图片右侧渐变到白色（图片 -> 白底自然过渡） */
.thumb-wrap::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 90rpx; /* 渐变宽度：60~120 都可以 */
  height: 100%;
  background: linear-gradient(to right, rgba(255,255,255,0), #ffffff);
  pointer-events: none;
  z-index: 2;
}

/* 右侧信息 */
.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
  overflow: hidden;
}

/* 用户信息 */
.user {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #eee;
}
.nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

/* 地点与留言 */
.location,
.message {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: normal;
  min-height: 72rpx;
}

/* 点赞与时间 */
.meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}
.like-text {
  font-size: 34rpx;
  color: #FF4D4F;
  font-weight: 700;
}
.time {
  font-size: 24rpx;
  color: #999;
}

/* 按钮行 */
.btn-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  gap: 20rpx;
}

/* 按钮样式 */
.btn {
  font-size: 26rpx;
  padding: 10rpx 28rpx;
  border-radius: 40rpx;
  font-weight: 500;
  color: #fff;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}
.btn.view { background: #AA66DD; }
.btn.like { background: #FF4D4F; }

/* 空态提示 */
.empty {
  margin-top: 120rpx;
  font-size: 28rpx;
  color: #888;
}

/* ===== 悬浮按钮（发布 / 筛选 / 排序） ===== */
.fab {
  position: fixed;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.18);
  z-index: 100;
}

.fab-publish {
  bottom: 40rpx;
  background-color: #1aad19;
}

.fab-filter {
  bottom: 160rpx;
  background-color: #AA66DD;
}

.fab-sort {
  bottom: 280rpx;
  background-color: #1E90FF;
}

.plus {
  font-size: 60rpx;
  color: #fff;
  line-height: 100rpx;
}

.fab-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1;
  text-align: center;
}

/* ===== 通用遮罩 ===== */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 90;
}

/* 底部面板（筛选 + 排序共用基础样式） */
.filter-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  padding: 32rpx 28rpx 48rpx;
  box-shadow: 0 -10rpx 30rpx rgba(0,0,0,0.1);
  z-index: 95;
  animation: slideUp 0.25s ease-out;
}

/* 动画 */
@keyframes slideUp {
  from { transform: translateY(100%); opacity: 0; }
  to   { transform: translateY(0); opacity: 1; }
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: #333;
}

/* 筛选角色行 */
.role-item {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 20rpx 8rpx;
  border-bottom: 1rpx solid #f2f3f5;
}

.role-name {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #333;
}

/* 滚动区域（可选） */
.panel-body {
  max-height: 600rpx;
}

/* ===== 面板按钮 ===== */
.panel-actions {
  display: flex;
  justify-content: flex-end;
  gap: 28rpx;
  margin-top: 36rpx;
}

.btn.primary {
  background-color: #AA66DD;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(170,102,221,0.3);
}

.btn.ghost {
  background-color: #fff;
  color: #333;
  border: 2rpx solid #e0e0e0;
}

.btn.primary:active {
  background-color: #994ECF;
}

.btn.ghost:active {
  background-color: #f5f5f5;
}

/* === 排序面板专用样式（蓝色系） === */
.sort-title {
  color: #1E90FF;
}

.sort-list {
  margin-top: 8rpx;
}

.sort-item {
  padding: 24rpx 8rpx;
  font-size: 30rpx;
  color: #333;
  border-bottom: 1rpx solid #f2f3f5;
}

.sort-item.active {
  color: #1E90FF;
  font-weight: 700;
}

.btn.sort-primary {
  background-color: #1E90FF;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(30,144,255,0.3);
}

/* === 追加：不侵入式的页面容器尺寸，避免拦截下拉手势 === */
:where(.rank-page) {
  min-height: 100vh;
  box-sizing: border-box;
}

/* 加载更多按钮区域 */
.load-more-wrapper {
  margin: 20rpx 0 40rpx;
  display: flex;
  justify-content: center;
}

.load-more-btn {
  padding: 16rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background-color: #AA66DD;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(170, 102, 221, 0.3);
}

.load-more-end {
  margin: 20rpx 0 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}
